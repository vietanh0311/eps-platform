# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Dữ liệu nguồn nhạy cảm (SĐT, MST, tài khoản nhận tiền) — không commit
/data/

# Tài liệu skill do trình cài tự sinh (vendored, không phải code dự án) + cấu hình máy cục bộ
/.agents/
/.windsurf/
.claude/skills/
skills-lock.json
.claude/settings.local.json

# Trạng thái/log launchd job đồng bộ ScaleF (scripts/scalef-sync-daily.sh) — máy cục bộ, không commit
.scalef-sync-state
.scalef-sync-lock/
scalef-sync.log
scalef-sync-launchd.log
